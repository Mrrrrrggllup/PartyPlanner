<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%logger{25}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Ktor HTTP requests -->
    <logger name="io.ktor.server.plugins.calllogging" level="INFO"/>
    <!-- App logs -->
    <logger name="com.partyplanner" level="DEBUG"/>
    <!-- Suppress noisy Netty/Exposed logs -->
    <logger name="io.netty" level="WARN"/>
    <logger name="Exposed" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>